{
  "name": "@astralibx/chat-engine",
  "version": "0.2.0",
  "description": "Real-time chat engine with Socket.IO gateway, session lifecycle, message routing, agent management, Redis caching, and FAQ/guided questions management",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hariprakash1997/astralib.git",
    "directory": "packages/chat/chat-engine"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chat",
    "socket.io",
    "real-time",
    "session",
    "messaging",
    "agent",
    "redis",
    "faq",
    "widget"
  ],
  "license": "MIT",
  "dependencies": {
    "@astralibx/chat-types": "^0.2.0",
    "@astralibx/core": "^1.2.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "mongoose": "^7.0.0 || ^8.0.0",
    "socket.io": "^4.0.0",
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "express": "^5.0.0",
    "ioredis": "^5.4.2",
    "mongoose": "^8.12.1",
    "socket.io": "^4.8.0",
    "typescript": "^5.8.2"
  }
}
