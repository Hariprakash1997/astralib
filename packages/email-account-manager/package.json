{
  "name": "@astralibx/email-account-manager",
  "version": "2.0.1",
  "description": "Reusable email account management with Gmail + SES support, BullMQ queues, health tracking, warmup, and optional approval workflow",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "email",
    "account-manager",
    "smtp",
    "ses",
    "gmail",
    "warmup",
    "health-tracking",
    "bullmq",
    "approval-workflow"
  ],
  "license": "MIT",
  "dependencies": {
    "@astralibx/core": "*",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "mongoose": "^7.0.0 || ^8.0.0",
    "ioredis": "^5.0.0",
    "bullmq": "^5.0.0",
    "nodemailer": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "bullmq": "^5.0.0",
    "express": "^5.0.0",
    "ioredis": "^5.4.2",
    "mongoose": "^8.12.1",
    "nodemailer": "^6.9.0",
    "typescript": "^5.8.2"
  }
}
